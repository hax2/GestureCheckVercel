{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    { "src": "/", "dest": "/public/gesture-rating-task.html" },
    { "src": "/gesture-rating-task", "dest": "/public/gesture-rating-task.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
